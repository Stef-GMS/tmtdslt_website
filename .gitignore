# See https://www.dartlang.org/guides/libraries/private-files

############################################################
# .gitignore                                               #
############################################################
# In theory a lot of this should be in the users' global   #
# gitignore files. Cruel experience has shown us that this #
# is not the case. So instead we include lots of guff in   #
# here.                                                    #
#                                                          #
# Original source came from raywenderlich.com Flutter team #
# template.
############################################################


############################################################
# If you're building an application, you may want to check-in
# your pubspec.lock
############################################################
pubspec.lock

##########################################################
# Ignoring generated files, as they pollute pull requests
# and can create merge conflicts
############################################################
*.g.dart
*.freezed.dart
!packages/*/lib/**/*.freezed.dart

############################################################
# Ignoring native folders of the example as they can be
# re-generated easily
############################################################
**/example/android/
**/example/ios/
**/example/web/
examples/**/android/
examples/**/ios/
examples/**/web/
examples/**/macos/


############################################################
# Directory created by dartdoc
# If you don't generate documentation locally you can remove
# this line.
############################################################
**/doc/api/


############################################################
# Flutter/Dart/Pub related
# Files and directories created by pub
############################################################
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
/build/
/coverage/


# dotenv environment variables file
.env*

# Avoid committing generated Javascript files:
*.dart.js
# Produced by the --dump-info flag.
*.info.json
# When generated by dart2js. Don't specify *.js if your
# project includes source files written in JavaScript.
*.js
*.js_
*.js.deps
*.js.map

.flutter-plugins
.flutter-plugins-dependencies

# Conventional directory for build output.
/build/

## AugmentCode ------------------
.augment/

# Exclude dependencies
node_modules

# Exclude secrets
.env

# Exclude build artifacts
out
build


# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/
